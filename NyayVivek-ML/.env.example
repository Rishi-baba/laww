# ============================================================
# NyayVivek-ML — Railway Environment Variables Reference
# ============================================================
# Copy these into your Railway service → Variables dashboard.
# Values marked [REQUIRED] must be set. Others are optional overrides.

# [OPTIONAL] Comma-separated list of your production frontend / backend URLs
# that are allowed to call this API (CORS).
# Example: https://lawra.vercel.app,https://lawra-server.up.railway.app
ALLOWED_ORIGINS_EXTRA=https://your-frontend.vercel.app,https://your-express-backend.up.railway.app

# [OPTIONAL] Override ML asset file paths if you store them in a volume
# Default: files are baked into the Docker image at /app/
# DATASET_PATH=/app/temp1.xlsx
# EMBEDDINGS_PATH=/app/case_embeddings.npy
# FAISS_INDEX_PATH=/app/legal_cases.index

# [AUTO-SET BY RAILWAY] Do NOT set manually — Railway injects this automatically
# PORT=8000
