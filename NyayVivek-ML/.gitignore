# Python virtual environment
venv/
.venv/
env/

# Python caching & bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.cache/
.pytest_cache/

# Jupyter Notebook checkpoints
*.ipynb
.ipynb_checkpoints/

# Environment files — .env.example IS committed; actual .env is NOT
.env
.env.local
.env.*.local

# OS specific files
.DS_Store
Thumbs.db

# HuggingFace & Sentence-Transformers model download cache
.huggingface/
.model/
sentence_transformers_cache/

# Editor configs
.vscode/
.idea/

# Docker build output (not needed in source control)
dist/

# NOTE: temp1.xlsx, case_embeddings.npy, legal_cases.index are intentionally
# tracked by git so they are available inside the Docker build context.
